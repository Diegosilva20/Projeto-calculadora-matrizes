{
  "name": "matrizes-adsense",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "mathjs": "^14.4.0",
    "mkdirp": "^3.0.1",
    "puppeteer-core": "^24.10.0",
    "react": "^19.1.0",
    "react-cookie-consent": "^9.0.0",
    "react-dom": "^19.1.0",
    "react-helmet": "^6.1.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.0",
    "react-snap": "^1.23.0",
    "rimraf": "^5.0.10",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "sitemap": "node ./sitemap-generator.mjs",
    "seo:routes": "node ./scripts/update-react-snap-routes.mjs",
    "build": "npm run sitemap && vite build && npm run seo",
    "seo": "npm run seo:routes && react-snap",
    "validate:prerender": "node ./scripts/validate-prerender-output.mjs",
    "preview": "vite preview"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "sitemap": "^8.0.0",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.7",
    "vite-plugin-pwa": "^1.2.0"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "reactSnap": {
    "source": "dist",
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "skipThirdPartyRequests": true,
    "include": [
      "/",
      "/tutorials",
      "/sobre",
      "/contato",
      "/politica-privacidade",
      "/termos-uso",
      "/tutorial/determinante-de-matrizes",
      "/tutorial/matriz-inversa",
      "/tutorial/escalonamento-gauss",
      "/tutorial/matriz-transposta",
      "/tutorial/multiplicacao-de-matrizes",
      "/tutorial/sistemas-lineares",
      "/tutorial/soma-de-matrizes",
      "/tutorial/subtracao-de-matrizes",
      "/tutorial/multiplicacao-por-escalar",
      "/tutorial/determinante-3x3-regra-de-sarrus",
      "/tutorial/o-que-e-uma-matriz",
      "/tutorial/matriz-identidade",
      "/tutorial/eliminacao-de-gauss"
    ]
  }
}
